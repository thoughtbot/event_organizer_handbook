<!doctype html>
<html lang="<%= site.locale %>">
  <head>
    <%= render "head", metadata: site.metadata, title: data.title %>
  </head>
  <body class="<%= data.layout %> <%= data.page_class %>">
    <div class="site-layout" id="site-layout">
      <aside class="sidebar">
        <button
          class="sidebar__toggle"
          id="sidebar-toggle"
          aria-expanded="true"
          aria-controls="sidebar-nav"
          aria-label="Toggle navigation"
        >&#8249;</button>

        <div class="sidebar__nav" id="sidebar-nav">
          <%= render Shared::Navbar.new(metadata: site.metadata, resource: resource) %>
        </div>
      </aside>

      <div class="site-body">
        <main>
          <%= yield %>
        </main>

        <%= render "footer", metadata: site.metadata %>
      </div>
    </div>
  </body>
</html>
